FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/feed";
    object      C_H2O;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Water concentration in the feed boundary-layer region [mol/m³].
//
// Analytical steady-state (feed region, x ∈ [0, 0.5 mm]):
//   C_f(x) = 1 − x / 1.5e-3  (linear, from 1.0 at inlet to 2/3 at interface)
//
// The gradient drives water toward the membrane; the Henry partition
// (K_H = 0.5) then drops the concentration to 1/3 on the membrane side.

dimensions      [0 -3 0 0 1 0 0];

internalField   uniform 0;

boundaryField
{
    feed_inlet
    {
        type        fixedValue;
        value       uniform 1;    // mol/m³  — bulk feed concentration
    }

    feed_to_membrane
    {
        // Henry partition at the feed/dense-membrane interface.
        // C_feed,face = (Ks_feed/Ks_m) × C_m,cell = 2 × C_m,cell
        // → C_m,face  = (Ks_m/Ks_feed) × C_feed,cell = 0.5 × C_feed,cell
        type        sievertsCoupledMixed;
        nbrField    C_H2O;
        T           T;
        Tnbr        T;
        partition   linear;
        Ks
        {
            X0          [0 -3 0 0 1 0 0] 2000;   // mol/m³  — feed solubility
            Ea          0;
        }
        KsNbr
        {
            X0          [0 -3 0 0 1 0 0] 1000;   // mol/m³  — membrane solubility
            Ea          0;
        }
        value       uniform 0;
    }

    sides
    {
        type        empty;
    }
}

