FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/membrane";
    object      C_H2O;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Water concentration in the dense membrane [mol/m³].
//
// Analytical steady state (membrane region, x ∈ [0.5 mm, 1.0 mm]):
//   C_m(x) = 1/3 − (x − 5e-4) / 1.5e-3  (linear, from 1/3 at interface to 0)
//
// The interface concentration C_m,if = 1/3 mol/m³ is exactly half the
// feed-side value (C_f,if = 2/3 mol/m³), demonstrating K_H = 0.5.

dimensions      [0 -3 0 0 1 0 0];

internalField   uniform 0;

boundaryField
{
    membrane_to_feed
    {
        // Mirror BC: swapped Ks and KsNbr relative to the feed side.
        type        sievertsCoupledMixed;
        nbrField    C_H2O;
        T           T;
        Tnbr        T;
        partition   linear;
        Ks
        {
            X0          [0 -3 0 0 1 0 0] 1000;   // mol/m³  — membrane solubility
            Ea          0;
        }
        KsNbr
        {
            X0          [0 -3 0 0 1 0 0] 2000;   // mol/m³  — feed solubility
            Ea          0;
        }
        value       uniform 0;
    }

    membrane_outlet
    {
        type        fixedValue;
        value       uniform 0;    // mol/m³  — permeate (clean water side)
    }

    sides
    {
        type        empty;
    }
}

