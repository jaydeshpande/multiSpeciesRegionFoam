FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/sic";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField   uniform 1;

boundaryField
{
    sic_outlet
    {
        type            zeroGradient;
    }
    sides
    {
        type            empty;
    }
    sic_to_pyc
    {
        type            extrapolatedCalculated;
        value           uniform 0;
    }
}


