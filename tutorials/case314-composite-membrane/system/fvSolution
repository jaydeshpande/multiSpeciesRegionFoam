FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Root-level defaults read by foamMultiRun before per-region overrides.
// Per-region files (system/pyc/fvSolution, system/sic/fvSolution) take precedence.

solvers
{
    "e.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-10;
        relTol          0;
    }

    "C_.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-10;
        relTol          0;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;

    residualControl
    {
        e               1e-8;
        "C_.*"          1e-8;
    }
}

relaxationFactors
{
    equations
    {
        ".*"            1;
    }
}

