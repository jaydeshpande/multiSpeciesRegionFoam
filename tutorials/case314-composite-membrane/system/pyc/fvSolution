FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system/pyc";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    // Thermal (e field from solid module)
    "e.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-10;
        relTol          0;
    }

    // Species concentration (C_T2 field from speciesSolid module)
    "C_.*"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-10;
        relTol          0;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;

    residualControl
    {
        e               1e-8;
        "C_.*"          1e-8;
    }
}

relaxationFactors
{
    equations { ".*" 1; }
}

