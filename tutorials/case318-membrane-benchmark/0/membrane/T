FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0/membrane";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Isothermal at 300 K. Ea = 0 in speciesProperties so D is constant regardless.
// fixedValue at both ends prevents numerical drift.

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    inlet
    {
        type        fixedValue;
        value       uniform 300;
    }

    outlet
    {
        type        fixedValue;
        value       uniform 300;
    }

    sides
    {
        type        empty;
    }
}

