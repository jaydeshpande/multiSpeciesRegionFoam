FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Case 3.1.5 — Simplified (isothermal) membrane distillation
//
// Water vapour diffuses through a hydrophobic porous membrane from the hot
// feed face (C_hot = 7 mol/m³) to the cold permeate face (C_cold = 1 mol/m³).
// Temperature is uniform at 333 K; D_eff is constant.
//
// τ_SS = L²/D_eff = (1e-3)²/1e-7 = 10 s
// Steady state is reached by t ≈ 50 s.  Run to 100 s for confirmation.
//
// Case 3.1.6 (thermally coupled) adds a temperature gradient, making D_eff(T)
// non-uniform and the face concentrations temperature-driven via vapour pressure.

application     foamMultiRun;

regionSolvers
{
    membrane    speciesSolid;
}

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         100;

deltaT          0.1;

writeControl    adjustableRunTime;
writeInterval   10;

purgeWrite      0;

writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;
adjustTimeStep  no;

libs
(
    "libspeciesSolid.so"
    "libspeciesTransport.so"
);

// ************************************************************************* //
