FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Case 3.1.6 — Thermally coupled membrane distillation
//
// The temperature gradient (333 K → 293 K) is solved by the solid thermal
// equation alongside the species equation for water vapour.  D_eff(T) follows
// Arrhenius with Ea = 10 000 J/mol, producing a 65 % variation in D across
// the 1 mm membrane and a curved (non-linear) steady-state C profile.
//
// Both thermal and species relaxation times are ≈ 1 s at these parameters.
// Steady state is well established by t = 10 s; run to 20 s for confirmation.

application     foamMultiRun;

regionSolvers
{
    membrane    speciesSolid;
}

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         20;

deltaT          0.05;

writeControl    adjustableRunTime;
writeInterval   2;

purgeWrite      0;

writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;
adjustTimeStep  no;

libs
(
    "libspeciesSolid.so"
    "libspeciesTransport.so"
);

// ************************************************************************* //
