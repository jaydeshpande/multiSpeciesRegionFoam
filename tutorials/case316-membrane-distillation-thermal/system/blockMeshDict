FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Polypropylene hollow-fibre membrane: L = 1 mm, cross-section 1 mm × 1 mm.
// 100 cells in x (dx = 10 µm).
//
// Case 3.1.6 — Thermally coupled membrane distillation.
// A temperature gradient (T_hot = 333 K → T_cold = 293 K) drives a variation
// in the effective pore diffusivity D_eff(T), producing a non-linear steady-
// state water-vapour concentration profile.  Compare with case 3.1.5 (isothermal)
// where D is constant and the profile is exactly linear.
//
// Physical parameters:
//   D_eff(T) = D0 · exp(−Ea/(R·T))
//   D0       = 4.67e-6 m²/s,  Ea = 10000 J/mol
//   D_eff(333 K) ≈ 1.27e-7 m²/s   (hot face)
//   D_eff(293 K) ≈ 7.70e-8 m²/s   (cold face)
//   C_hot = 7.0 mol/m³  (p_sat(60°C) / RT),  C_cold = 1.0 mol/m³
//   Membrane: PP  rho = 900 kg/m³,  Cv = 1900 J/(kg·K),  kappa = 0.17 W/(m·K)
//   τ_T ≈ τ_C ≈ 1 s  →  steady state well established by t = 20 s

convertToMeters 1;

vertices
(
    (0      0      0    )   // 0
    (1e-3   0      0    )   // 1
    (1e-3   1e-3   0    )   // 2
    (0      1e-3   0    )   // 3
    (0      0      1e-3 )   // 4
    (1e-3   0      1e-3 )   // 5
    (1e-3   1e-3   1e-3 )   // 6
    (0      1e-3   1e-3 )   // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) membrane (100 1 1) simpleGrading (1 1 1)
);

boundary
(
    hot_face
    {
        type    patch;
        faces   ( (0 4 7 3) );   // x = 0  (feed side, T_hot = 333 K)
    }
    cold_face
    {
        type    patch;
        faces   ( (1 2 6 5) );   // x = L  (permeate side, T_cold = 293 K)
    }
    sides
    {
        type    empty;
        faces
        (
            (0 1 5 4)
            (3 7 6 2)
            (0 3 2 1)
            (4 5 6 7)
        );
    }
);

