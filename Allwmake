#!/bin/sh
# Build script for multiSpeciesRegionFoam
#
# Usage:
#   source $FOAM_ETC/bashrc     # or your OpenFOAM-13 activation
#   ./Allwmake                  # builds libraries in dependency order
#
# Parallel builds:
#   ./Allwmake -j 8
#
# Clean:
#   ./Allwclean

cd "$(dirname "$0")" || exit 1

set -e

echo "==> Building libspeciesTransport"
wmake libso src/speciesTransport "$@"

echo "==> Building libspeciesCoupling"
wmake libso src/speciesCoupling "$@"

echo "==> Building libspeciesSolid (solver module)"
wmake libso src/speciesSolid "$@"

echo "==> Building libspeciesPost (post-processing)"
wmake libso src/speciesPost "$@"

echo "==> Build complete"
